{
  "manifest_version": 3,
  "name": "LeetPilot",
  "version": "1.0.0",
  "description": "Learn. Organize. Improve.",

  "action": {
    "default_title": "LeetPilot"
  },

  "background": {
    "service_worker": "src/background/background.ts",
    "type": "module"
  },

  "permissions": [
    "storage",
    "tabs"
  ],

  "host_permissions": [
    "https://leetcode.com/*"
  ]
}